---
interface Props {
  label: string;
  top?: string;
  left?: string;
  right?: string;
  bottom?: string;
}

const { label, top, left, right, bottom } = Astro.props;

const style = [
  top && `top: ${top}`,
  left && `left: ${left}`,
  right && `right: ${right}`,
  bottom && `bottom: ${bottom}`,
].filter(Boolean).join('; ');
---

<span class="coord-label" style={style}>{label}</span>

<style>
  .coord-label {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.15em;
    color: var(--color-reg-mark);
    pointer-events: none;
    user-select: none;
    z-index: 2;
  }
</style>
