---
import RegistrationMark from './RegistrationMark.astro';

const title = 'MOMENTUM LABS';
const letters = title.split('');
---

<section class="hero" id="hero">
  <RegistrationMark position="top-left" size={28} />
  <RegistrationMark position="top-right" size={28} />
  <RegistrationMark position="bottom-left" size={28} />
  <RegistrationMark position="bottom-right" size={28} />

  <!-- Technical annotation -->
  <div class="hero__annotation hero__annotation--top">
    <span>[SYS.INIT]</span>
    <span>v0.1.0</span>
    <span>2026.04</span>
  </div>

  <div class="hero__content">
    <!-- Title as character grid -->
    <div class="hero__title" aria-label={title}>
      {letters.map((char, i) => (
        <span
          class={`hero__char ${char === ' ' ? 'hero__char--space' : ''}`}
          style={`--char-index: ${i};`}
        >
          {char === ' ' ? '\u00A0' : char}
        </span>
      ))}
    </div>

    <p class="hero__tagline">
      Momentum is everything.<br />
      <span class="text-muted">Starting from zero is the hardest part.</span>
    </p>

    <!-- Fibonacci spiral -->
    <div class="hero__spiral">
      <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="spiral-svg">
        <!-- Fibonacci golden spiral approximation -->
        <path
          d="M100 100
             A5 5 0 0 1 105 100
             A8 8 0 0 1 105 108
             A13 13 0 0 1 92 108
             A21 21 0 0 1 92 87
             A34 34 0 0 1 126 87
             A55 55 0 0 1 126 142"
          stroke="var(--color-orange)"
          stroke-width="1"
          opacity="0.4"
          fill="none"
        />
        <!-- Grid squares showing Fibonacci -->
        <rect x="100" y="95" width="10" height="10" stroke="var(--color-orange-dim)" stroke-width="0.5" opacity="0.3" />
        <rect x="97" y="100" width="16" height="16" stroke="var(--color-orange-dim)" stroke-width="0.5" opacity="0.25" />
        <rect x="87" y="84" width="26" height="26" stroke="var(--color-orange-dim)" stroke-width="0.5" opacity="0.2" />
        <rect x="87" y="84" width="42" height="42" stroke="var(--color-orange-dim)" stroke-width="0.5" opacity="0.15" />
      </svg>
    </div>
  </div>

  <div class="hero__annotation hero__annotation--bottom">
    <span>00:00:00</span>
    <span>COORD [0,0]</span>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll scroll-indicator">
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
      <rect x="1" y="1" width="14" height="22" rx="7" stroke="var(--color-text-muted)" stroke-width="1" />
      <circle cx="8" cy="7" r="2" fill="var(--color-orange)" />
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: var(--sp-55);
    overflow: hidden;
  }

  .hero__content {
    text-align: center;
    position: relative;
  }

  .hero__title {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
    margin-bottom: var(--sp-34);
  }

  .hero__char {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(28px, 5vw, 60px);
    height: clamp(36px, 6.5vw, 78px);
    font-size: clamp(1.5rem, 4.5vw, 4.5rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-text);
    border: 1px solid transparent;
    transition: border-color 0.3s ease;
    opacity: 0;
    animation: char-in 0.4s ease forwards;
    animation-delay: calc(var(--char-index) * 0.04s + 0.3s);
  }

  .hero__char:hover {
    border-color: var(--color-orange);
    color: var(--color-orange);
  }

  .hero__char--space {
    width: clamp(14px, 2vw, 30px);
    border: none;
  }

  @keyframes char-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__tagline {
    font-size: clamp(0.875rem, 1.5vw, 1.25rem);
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text);
  }

  .hero__spiral {
    position: absolute;
    bottom: -40px;
    right: -80px;
    width: 200px;
    height: 200px;
    opacity: 0.5;
  }

  .spiral-svg {
    width: 100%;
    height: 100%;
  }

  .hero__annotation {
    position: absolute;
    display: flex;
    gap: var(--sp-13);
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: var(--color-reg-mark);
    text-transform: uppercase;
  }

  .hero__annotation--top {
    top: var(--sp-34);
    left: var(--sp-34);
  }

  .hero__annotation--bottom {
    bottom: var(--sp-55);
    right: var(--sp-34);
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--sp-21);
    left: 50%;
    transform: translateX(-50%);
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--sp-34) var(--sp-13);
    }

    .hero__spiral {
      display: none;
    }

    .hero__annotation {
      display: none;
    }
  }
</style>
